{
  "manifest_version": 3,
  "name": "WA Web Sidebar Toggle",
  "version": "0.0.0",
  "description": "Add a toggle button to WhatsApp Web to hide or show the chat/status/channels sidebar, giving you a distraction-free chat view.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [],
  "host_permissions": ["https://web.whatsapp.com/*"]
}
