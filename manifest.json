{
  "manifest_version": 3,
  "name": "WA Web Sidebar Toggle",
  "version": "0.2.5",
  "description": "Hide or show the WhatsApp Web sidebar with one click or Alt+S distraction-free chats, clean screen sharing and multi-tasking.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon128.png",
    "48": "icons/icon48.png",
    "64": "icons/icon128.png",
    "128": "icons/icon128.png",
    "256": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon128.png",
      "48": "icons/icon48.png",
      "64": "icons/icon128.png",
      "128": "icons/icon128.png",
      "256": "icons/icon128.png"
    },
    "default_title": "WA Web Sidebar Toggle"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "welcome/welcome.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
