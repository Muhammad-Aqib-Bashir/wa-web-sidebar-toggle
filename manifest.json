{
  "manifest_version": 3,
  "name": "WA Web Sidebar Toggle",
  "version": "1.0.0",
  "description": "Instantly hide or show the WhatsApp Web chat sidebar for a distraction-free, full-screen chat experience.",
  "permissions": [],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "WA Web Sidebar Toggle"
  }
}
