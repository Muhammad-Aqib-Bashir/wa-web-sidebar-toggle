{
  "manifest_version": 3,
  "name": "WA Web Sidebar Toggle",
  "version": "0.2.0",
  "description": "Add a button to WhatsApp Web to hide or show the chat/status/channels sidebar, giving you a distraction free chat view.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon128.png",
    "48": "icons/icon48.png",
    "64": "icons/icon128.png",
    "128": "icons/icon128.png",
    "256": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon128.png",
      "48": "icons/icon48.png",
      "64": "icons/icon128.png",
      "128": "icons/icon128.png",
      "256": "icons/icon128.png"
    },
    "default_title": "WA Web Sidebar Toggle"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [],
  "host_permissions": ["https://web.whatsapp.com/*"]
}
